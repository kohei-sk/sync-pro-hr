# Supabase (必須)
# Supabase Dashboard > Settings > API から取得
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Resend (Phase 2 メール送信用)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@pitasuke.com

# Vercel Cron (Phase 4 リマインダー用)
CRON_SECRET=your-random-secret-string-here

# Google OAuth (Phase 5 カレンダー連携用)
# Google Cloud Console > APIs & Services > Credentials で取得
# Authorized redirect URIs: https://your-domain.com/api/auth/google/callback
GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxx

# Slack OAuth (Slack 連携用)
# api.slack.com/apps でアプリを作成して取得
# OAuth Scopes (Bot Token Scopes): incoming-webhook
SLACK_CLIENT_ID=your-slack-client-id
SLACK_CLIENT_SECRET=your-slack-client-secret
# Slack App の「Redirect URLs」に登録した URL と完全一致させる（ローカルは https://localhost:3000/api/auth/slack/callback など）
SLACK_REDIRECT_URI=https://your-domain.com/api/auth/slack/callback

# アプリURL (メール内リンク等)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Corn
CRON_SECRET=XXXXXXXXXXXX
